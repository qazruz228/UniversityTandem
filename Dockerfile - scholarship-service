FROM maven:3.9.6-eclipse-temurin-17 AS build

WORKDIR /app
COPY pom.xml .

COPY scholarship-service/pom.xml scholarship-service/pom.xml

RUN mvn -B -f scholarship-service/pom.xml dependency:go-offline

COPY scholarship-service/src scholarship-service/src

RUN mvn -B -DskipTests -f scholarship-service/pom.xml clean package

FROM amazoncorretto:17-alpine

WORKDIR /app

RUN addgroup -S spring && adduser -S spring -G spring

COPY --chown=spring:spring --from=build /app/scholarship-service/target/*.jar app.jar

EXPOSE 10000

USER spring:spring

ENTRYPOINT ["java","-jar","app.jar"]
