FROM maven:3.9.6-eclipse-temurin-17 AS build

WORKDIR /app
COPY pom.xml .

COPY headteacher-service/pom.xml headteacher-service/pom.xml

RUN mvn -B -f headteacher-service/pom.xml dependency:go-offline

COPY headteacher-service/src headteacher-service/src

RUN mvn -B -DskipTests -f headteacher-service/pom.xml clean package

FROM amazoncorretto:17-alpine

WORKDIR /app

RUN addgroup -S spring && adduser -S spring -G spring

COPY --chown=spring:spring --from=build /app/headteacher-service/target/*.jar app.jar

EXPOSE 10000

USER spring:spring

ENTRYPOINT ["java","-jar","app.jar"]