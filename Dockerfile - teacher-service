FROM maven:3.9.6-eclipse-temurin-17 AS build

WORKDIR /app
COPY pom.xml .

COPY teacher-service/pom.xml teacher-service/pom.xml

RUN mvn -B -f teacher-service/pom.xml dependency:go-offline

COPY teacher-service/src teacher-service/src

RUN mvn -B -DskipTests -f teacher-service/pom.xml clean package

FROM amazoncorretto:17-alpine

WORKDIR /app

RUN addgroup -S spring && adduser -S spring -G spring

COPY --chown=spring:spring --from=build /app/teacher-service/target/*.jar app.jar

EXPOSE 10000

USER spring:spring

ENTRYPOINT ["java","-jar","app.jar"]